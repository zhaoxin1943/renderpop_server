ENVIRONMENT=development
WEB_ORIGIN=http://localhost:3000
API_PREFIX=/api

# Async app runtime (aiomysql)
DATABASE_URL=mysql+aiomysql://renderpop:renderpop@127.0.0.1:3306/renderpop?charset=utf8mb4
# Alembic / sync tooling (pymysql)
DATABASE_URL_SYNC=mysql+pymysql://renderpop:renderpop@127.0.0.1:3306/renderpop?charset=utf8mb4

REDIS_URL=redis://127.0.0.1:6379/0
# Required when Redis is shared with other projects. All keys use this prefix
# (Dramatiq queue namespace + app.core.redis_keys.redis_key).
REDIS_PREFIX=renderpop_server_

SESSION_SECRET=change-me-to-a-long-random-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

DODO_API_KEY=
DODO_WEBHOOK_KEY=
# test_mode -> products.environment=sandbox; live_mode -> live
DODO_ENVIRONMENT=test_mode
DODO_RETURN_URL=http://localhost:3000/billing/success
# Public base for RunningHub webhooks (use tunnel in local dev)
PUBLIC_API_BASE_URL=http://localhost:8000

RUNNINGHUB_API_KEY=
RUNNINGHUB_BASE_URL=https://www.runninghub.ai

# Pollo AI video (https://docs.pollo.ai)
POLLO_API_KEY=
POLLO_BASE_URL=https://pollo.ai/api/platform
# Base64 webhook secret from https://api.pollo.ai/webhook (optional in dev)
POLLO_WEBHOOK_SECRET=

AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=renderpop-assets
S3_ASSET_PREFIX=media
